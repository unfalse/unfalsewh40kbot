{
  "name": "vox-logis-lexmechanic",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && cp src/config/*.yaml dist/config/",
    "start": "node dist/bot.js",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/bot.ts",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "axios": "^1.7.9",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "grammy": "^1.31.3",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.4",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
