# Telegram (BotFather)
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# https://openweathermap.org/api
OPENWEATHER_API_KEY=ffffffffffffffffffffffffffffffff

# LLM-бэкенд. По умолчанию: gemini (требует GEMINI_API_KEY).
# Для локального Ollama укажи: localhost:11434 (GEMINI_API_KEY не нужен).
LLM=gemini

# https://aistudio.google.com/apikey
# Не нужен, если LLM=localhost:11434
GEMINI_API_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Имя yaml-файла с сообщениями и системными промптами.
# Относительный путь резолвится из директории конфигов (src/config/ или dist/config/).
# Абсолютный путь используется как есть.
# По умолчанию: shodan.yaml
# Примеры: shodan.yaml | lexmechanic.yaml | /etc/bot/custom.yaml
MESSAGES=shodan.yaml

# Директория для хранения пользовательских настроек (preferences.json).
# По умолчанию: ./data (относительно рабочей директории).
# В Docker задаётся автоматически через docker-compose.yml, менять не нужно.
# DATA_DIR=/app/data
