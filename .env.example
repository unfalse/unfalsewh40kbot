# Имя Docker-контейнера. По умолчанию: vox-logis-bot
CONTAINER_NAME=vox-logis-bot

# Порт health-сервера. По умолчанию: 3000
HTTP_PORT=3000

# Telegram (BotFather)
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# https://openweathermap.org/api
OPENWEATHER_API_KEY=ffffffffffffffffffffffffffffffff

# Адрес Ollama. Если указан — запросы идут через Ollama, GEMINI_API_KEY не нужен.
# Для локального запуска (вне Docker): LLM_HOST=http://localhost:11434
# Для запуска из Docker-контейнера:   LLM_HOST=http://host.docker.internal:11434
# LLM_HOST=http://host.docker.internal:11434

# Модель Ollama. Используется только при наличии LLM_HOST. По умолчанию: gemma4
# LLM=gemma4

# https://aistudio.google.com/apikey
# Не нужен, если задан LLM_HOST
GEMINI_API_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Имя yaml-файла с сообщениями и системными промптами.
# Относительный путь резолвится из директории конфигов (src/config/ или dist/config/).
# Абсолютный путь используется как есть.
# По умолчанию: shodan.yaml
# Примеры: shodan.yaml | lexmechanic.yaml | /etc/bot/custom.yaml
MESSAGES=shodan.yaml

# Максимум одновременных запросов к LLM. По умолчанию: 1 (очередь).
# LLM_CONCURRENCY=1

# Лимиты токенов для LLM-ответов (работают для Gemini и Ollama).
# Значения по умолчанию указаны ниже, раскомментируй чтобы переопределить.
# LLM_TOKENS_WEATHER=300
# LLM_TOKENS_SUMMARY=700
# LLM_TOKENS_ERROR=200
# LLM_TOKENS_CHAT=200
# LLM_TOKENS_PLAIN=300
# LLM_TOKENS_WHASK=300
# LLM_TOKENS_AINEWS=600

# Директория для хранения пользовательских настроек (preferences.json).
# По умолчанию: ./data (относительно рабочей директории).
# В Docker задаётся автоматически через docker-compose.yml, менять не нужно.
# DATA_DIR=/app/data
